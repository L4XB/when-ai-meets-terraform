@article{gunawat_ai-enhanced_nodate,
	title = {{AI}-Enhanced Infrastructure as Code ({IaC}) for Smart Configuration Management},
	abstract = {The integration of Artificial Intelligence ({AI}) with Infrastructure as Code ({IaC}) is transforming cloud infrastructure management through intelligent automation, predictive analytics, and self-healing capabilities. While traditional {IaC} streamlines provisioning, {AI}-driven approaches optimize resource allocation, enhance security compliance, and reduce human errors. This paper explores the role of machine learning ({ML}), reinforcement learning ({RL}), and natural language processing ({NLP}) in automating {IaC} workflows, predicting failures, and dynamically adjusting configurations for efficiency. Additionally, {AI}-powered anomaly detection enables proactive issue resolution, minimizing downtime through self-remediation. Case studies and simulations demonstrate {AI}’s impact on scalability, resilience, and operational efficiency in cloud environments. The research also addresses key challenges, such as {AI} model interpretability, security risks, and integration complexities, while proposing best practices for {AI}-{IaC} adoption. By analyzing state-of-the-art methodologies, including predictive analytics for capacity planning and {NLP}-driven intelligent code generation, this study highlights {AI}’s transformative potential in modern {IT} ecosystems. The findings emphasize {AI}’s role in reshaping infrastructure automation, driving scalability, and enhancing operational efficiency in {DevOps} and cloud computing.},
	author = {Gunawat, Chhaya and Khanna, Atul},
	langid = {english},
	file = {PDF:/Users/lukasbuck/Zotero/storage/5M56XZ44/Gunawat und Khanna - AI-Enhanced Infrastructure as Code (IaC) for Smart Configuration Management.pdf:application/pdf},
}


